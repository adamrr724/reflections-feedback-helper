{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "X-MCP-Toolsets": "default,copilot_spaces,copilot"
      }
    },
    "azure-data-explorer": {
      "command": "${workspaceFolder}/tools/.venv/bin/python3",
      "args": ["${workspaceFolder}/tools/mcp_kusto_readonly_server.py"],
      "tools": ["*"]
    }
  }
}
